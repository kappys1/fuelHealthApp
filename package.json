{
  "name": "fuelboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" next dev",
    "build": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" next build",
    "start": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" drizzle-kit migrate",
    "db:push": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" drizzle-kit push",
    "db:seed": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" tsx src/server/db/seed.ts",
    "migrate:poc": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" tsx src/server/db/migrate-poc.ts",
    "backfill:grams": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" tsx src/server/db/backfill-grams.ts",
    "migrate:products": "NODE_EXTRA_CA_CERTS=\"$HOME/.config/roche-ca.pem\" tsx src/server/db/migrate-products.ts",
    "hash-password": "tsx scripts/hash-password.ts",
    "audit:contrast": "tsx scripts/audit-contrast.ts",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.10",
    "@ai-sdk/provider-utils": "^5.0.6",
    "@neondatabase/serverless": "^1.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@serwist/turbopack": "^9.5.11",
    "@tanstack/react-query": "^5.101.2",
    "@vercel/blob": "^2.6.1",
    "ai": "^7.0.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "idb": "^8.0.3",
    "iron-session": "^8.0.4",
    "lucide-react": "~1.23.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "serwist": "^9.5.11",
    "shadcn": "^4.13.0",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@swc/core"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
